# ==========================================
# AI-HCP-CRM Backend Environment Variables
# ==========================================

# -----------------------------
# FastAPI Configuration
# -----------------------------
APP_NAME=AI-HCP-CRM
APP_ENV=development
DEBUG=True
HOST=127.0.0.1
PORT=8000

# -----------------------------
# Database Configuration
# PostgreSQL
# -----------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hcpcrm
DB_USER=postgres
DB_PASSWORD=your_password

# SQLAlchemy Database URL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/hcpcrm

# -----------------------------
# Alternative MySQL Configuration
# Uncomment if using MySQL
# DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/hcpcrm
# -----------------------------

# -----------------------------
# Groq API Configuration
# -----------------------------
GROQ_API_KEY=your_groq_api_key_here

# Primary LLM
GROQ_MODEL=gemma2-9b-it

# Optional Model
FALLBACK_MODEL=llama-3.3-70b-versatile

# -----------------------------
# LangGraph Configuration
# -----------------------------
LANGGRAPH_DEBUG=True

# -----------------------------
# CORS Configuration
# -----------------------------
CORS_ORIGINS=http://localhost:5173

# -----------------------------
# Security
# -----------------------------
SECRET_KEY=replace_with_a_secure_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=INFO

# -----------------------------
# Application Settings
# -----------------------------
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_LANGUAGE=en
